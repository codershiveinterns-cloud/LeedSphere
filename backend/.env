# --- Email (Resend) ---
# Get a key at https://resend.com — free tier covers ~100 emails/day.
# If unset, invite emails fall back to a console.warn (link is logged so
# local dev still works without a mail provider).
RESEND_API_KEY=re_ZZTEFXnq_A1d1mzhSA3iVpDabcdUQXACb
# Origin used in invite links (Accept Invite button → /accept-invite/:token).
FRONTEND_URL=https://leed-sphere.vercel.app
# Optional override of the From address. Must be on a domain you've verified
# in Resend; otherwise leave the default and Resend rejects the send.
# MAIL_FROM=Leedsphere <noreply@leedsphere.app>

# --- CORS (REST + Socket.IO) ---
# Comma-separated list of additional allowed origins. localhost dev, the
# Vercel production URL, and any *.vercel.app preview are already allowed
# by default — only add custom hosts here.
# CORS_ORIGIN=https://app.leedsphere.com,https://staging.leedsphere.com

# --- Firebase Admin SDK ---
# Project ID (must match the frontend's VITE_FIREBASE_PROJECT_ID)
FIREBASE_PROJECT_ID=leed-sphere
# Pick ONE of the two below:
# (a) Path to a downloaded service-account JSON key file.
#     Get it at Firebase Console → Project settings → Service accounts → Generate new private key.
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\leed-sphere-firebase-adminsdk.json
# (b) Or paste the entire JSON contents on one line (preferred for hosted envs):
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"leed-sphere",...}
